# Driveway Advocate — environment variables
# Copy to .env.local and fill in. Never commit real values.

# Supabase project URL and public anon key (safe to expose to the browser).
# The anon key is constrained by Row Level Security — it must never be able to
# read other buyers' deals. See supabase/migrations for the RLS policies.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY. Never expose to the browser. Bypasses RLS and
# is used exclusively by the private review console / server routes.
SUPABASE_SERVICE_ROLE_KEY=

# Review console password. DELIBERATE STOPGAP for v1 — single shared password,
# not real auth. Replace with proper authentication before launch.
CONSOLE_PASSWORD=

# Upload quote parser provider. Optional. Defaults to "none" (no extraction —
# the buyer confirms/enters fields, which is the honest v1 behavior). Set to a
# real provider once implemented in src/lib/parse/extract.ts (a provider may
# need its own API key env var).
PARSE_PROVIDER=none

# MarketCheck API key — SERVER ONLY. Never expose to the browser, never commit a
# real value. Powers the vehicle market-price range behind the Deal Score
# (src/lib/marketcheck/client.ts). Absent → price fairness is skipped gracefully.
# Rotate immediately if it ever leaks; enable the IP allowlist in MarketCheck.
MARKETCHECK_API_KEY=

# MarketCheck PREMIUM endpoints (Basic plan and up). Default OFF so the Free plan
# (Inventory Search only, 500 calls/mo) never spends a call on — or 403s against —
# an endpoint it doesn't have. With these off, each search makes ONE billable call.
# Set to "true" after upgrading to light up the matching feature (no code change):
#   MARKETCHECK_SPECS_ENABLED   — NeoVIN/Epi specs decode (MSRP + richer equipment)
#   MARKETCHECK_HISTORY_ENABLED — Dealer Recent Inventory (real price-history chart)
#   MARKETCHECK_DEALER_ENABLED  — Dealer API (same-dealer inventory rows)
MARKETCHECK_SPECS_ENABLED=false
MARKETCHECK_HISTORY_ENABLED=false
MARKETCHECK_DEALER_ENABLED=false
